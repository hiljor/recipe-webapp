generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ingredients {
  id                 Int                  @id @default(autoincrement())
  name               String               @unique
  recipe_ingredients recipe_ingredients[]
}

model recipe_ingredients {
  recipe_id     Int
  ingredient_id Int
  quantity      Decimal     @db.Decimal(10, 4)
  unit          String?
  pos           Int
  ingredients   ingredients @relation(fields: [ingredient_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recipes       recipes     @relation(fields: [recipe_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([recipe_id, ingredient_id, pos])
}

model recipes {
  id                 Int                  @id @default(autoincrement())
  title              String
  author_id          Int
  image_url          String?
  flavour_text       String?
  servings           Int
  added              DateTime             @db.Date
  updated            DateTime             @db.Date
  recipe_ingredients recipe_ingredients[]
  users              users                @relation(fields: [author_id], references: [pk], onDelete: NoAction, onUpdate: NoAction)
  steps              steps[]
  
  @@index([author_id])
}

model steps {
  recipe_id Int
  type      instruction_type
  text      String
  pos       Int
  recipes   recipes          @relation(fields: [recipe_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([recipe_id, pos])
}

model users {
  pk           Int       @id @default(autoincrement())
  id           String    @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  display_name String    @db.VarChar(255)
  email        String    @unique
  password     String
  recipes      recipes[]
}

enum instruction_type {
  step
  tip
  note
}
