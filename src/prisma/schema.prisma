generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Ingredient {
  id               Int                @id @default(autoincrement())
  name             String             @unique
  recipeIngredient RecipeIngredient[]

  @@map("Ingredient")
}

model RecipeIngredient {
  recipeId     Int
  ingredientId Int
  quantity     Decimal    @db.Decimal(10, 4)
  unit         String?
  pos          Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([recipeId, ingredientId, pos])
  @@map("RecipeIngredient")
}

model Recipe {
  id               Int                @id @default(autoincrement())
  title            String
  authorId         Int
  imageUrl         String?
  flavourText      String?
  servings         Int
  added            DateTime           @db.Date
  updated          DateTime           @db.Date
  user             User               @relation(fields: [authorId], references: [pk], onDelete: NoAction, onUpdate: NoAction)
  recipeIngredient RecipeIngredient[]
  step             Step[]

  @@index([authorId])
  @@map("Recipe")
}

model Step {
  recipeId Int
  type     InstructionType
  text     String
  pos      Int
  recipe   Recipe          @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([recipeId, pos])
  @@map("Step")
}

model User {
  pk          Int      @id @default(autoincrement())
  id          String   @unique @default(dbgenerated("gen_random_uuid()"))
  displayName String   @db.VarChar(255)
  email       String   @unique
  password    String
  recipe      Recipe[]

  @@map("User")
}

enum InstructionType {
  step
  tip
  note
}
